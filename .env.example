# Client-exposed keys (inlined into the production bundle).
# Only list keys that are safe to expose to browsers.
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SENTRY_DSN=
VITE_CHANNEL_TALK_PLUGIN_KEY=
VITE_ENABLE_SENTRY=false

# NOTE: Do NOT add server-side secrets with the VITE_ prefix.
# - Slack webhook and EIA API key are proxied through the Rails backend.
# - See CLAUDE.md for the environment variable policy.

# Rails backend mail/auth configuration (server-side only; set on Render, never expose with VITE_)
FRONTEND_URL=https://smart-quote-emax.vercel.app
MAILER_FROM=
RESEND_API_KEY=
CORS_ORIGINS=https://smart-quote-emax.vercel.app
